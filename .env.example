# ============================================================
# luck428.com (pj-yotsuba-fudousan) 環境変数
# Supabase移行後の必須env（設計_Supabaseスキーマ_luck428移行_v1.md §6）
# ローカルでは .env.local にコピーして値を設定する（.env* はコミットしない）
# ============================================================

# Supabase Postgres（pooler / pgbouncer 経由の接続文字列）
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# prisma migrate 用の直結続（direct connection）
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Supabase Auth（クライアント公開可・Auth専用）
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# APIルートのトークン検証・Storage書き込み専用（サーバーのみ・公開厳禁）
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# --- 既存（変更なし・本番に設定済み） ---
# RESEND_API_KEY=          # 問い合わせフォームのメール送信
# ANTHROPIC_API_KEY=       # 翻訳・SEO生成・LINKA

# GA4 計測ID（本番のみ設定。未設定ならタグを出力しない）
NEXT_PUBLIC_GA_ID=
